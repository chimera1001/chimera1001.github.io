          <p class="mt-1">
            {e.orgLink ? (
              <a href={e.orgLink} target="_blank" class="text-blue-300 underline-offset-4 hover:text-blue-100 hover:underline">{e.org}</a>
            ) : (
              <span class="text-blue-300">{e.org}</span>
            )}
